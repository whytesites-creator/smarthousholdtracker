# ─────────────────────────────────────────────────────────────────────────────
# Smart Household Tracker — Web App Environment Variables
#
# For Cloudflare Pages, set these in:
#   Dashboard → Workers & Pages → sht-web → Settings → Environment Variables
#
# For local development, copy to .env.local — NEVER commit .env.local to Git.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Worker URL (from wrangler deploy output)
VITE_API_BASE_URL=https://sht-api-worker.your-subdomain.workers.dev
