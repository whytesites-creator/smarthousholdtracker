# ─────────────────────────────────────────────────────────────────────────────
# Smart Household Tracker — Web App Environment Variables
#
# For local dev:   copy to .env.local  → never commit .env.local
# For production:  set in Cloudflare Pages → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── API base URL ──────────────────────────────────────────────────────────────
# LOCAL DEV  : leave blank (Vite proxy at /api forwards to http://localhost:8787)
# PRODUCTION : set to your deployed Worker URL, e.g.
#              https://smarthousholdtracker.your-subdomain.workers.dev
VITE_API_BASE_URL=
